<?xml version="1.0" encoding="utf-8"?>
<!--
    SplashScreen API theme — shown BEFORE Compose initialises.
    Pure black background. The "hushtv." wordmark is handled by the
    Compose HushSplashScreen overlay after Activity.onCreate so we can
    animate the logo fade + cyan progress bar per design spec.
-->
<resources>
    <style name="Theme.HushTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_black</item>
        <!-- Intentionally NO animated icon: Compose renders the wordmark
             so we control typography & timing. -->
        <item name="postSplashScreenTheme">@style/Theme.HushTV</item>
    </style>
</resources>
