<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Splash theme shown BEFORE Compose initialises — gives an instant visual
      response on app launch. The icon fades out automatically when the
      activity calls installSplashScreen().
    -->
    <style name="Theme.HushTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.HushTV</item>
    </style>
</resources>
