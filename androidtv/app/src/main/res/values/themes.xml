<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base theme — pure black background everywhere.
      windowBackground MUST be pure black on first attach to prevent any
      white flash before Compose takes over.
    -->
    <style name="Theme.HushTV" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@color/bg_black</item>
        <item name="android:colorBackground">@color/bg_black</item>
        <item name="android:statusBarColor">@color/bg_black</item>
        <item name="android:navigationBarColor">@color/bg_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
