<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_black">#000000</color>
    <color name="cyan_400">#06B6D4</color>
    <color name="ic_launcher_background">#06091A</color>
    <color name="slate_600">#475569</color>
    <color name="surface_elev">#1E293B</color>
    <color name="surface_navy">#0F172A</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">HushTV</string>
    <style name="Theme.HushTV" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@color/bg_black</item>
        <item name="android:colorBackground">@color/bg_black</item>
        <item name="android:statusBarColor">@color/bg_black</item>
        <item name="android:navigationBarColor">@color/bg_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.HushTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_empty</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/bg_black</item>
        <item name="postSplashScreenTheme">@style/Theme.HushTV</item>
    </style>
</resources>