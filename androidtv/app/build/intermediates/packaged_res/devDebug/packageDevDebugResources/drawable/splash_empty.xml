<?xml version="1.0" encoding="utf-8"?>
<!--
  Transparent 1dp drawable used as windowSplashScreenAnimatedIcon.
  Keeps the SplashScreen API from forcibly rendering the launcher icon
  (which gets cropped to a circle and looks bad). We show only the
  pure-black window background until the Compose splash takes over.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:fillColor="#00000000" android:pathData="M0,0h1v1h-1z" />
</vector>
